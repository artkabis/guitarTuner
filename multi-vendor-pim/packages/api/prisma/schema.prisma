generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Product ────────────────────────────────────────────────────────────────

model Product {
  id                String        @id @default(cuid())
  sku               String        @unique
  name              String
  slug              String        @unique
  status            ProductStatus @default(DRAFT)

  description       String?
  description_html  String?
  short_description String?

  price             Decimal       @db.Decimal(10, 2)
  compare_at_price  Decimal?      @db.Decimal(10, 2)
  currency          String        @default("EUR")

  stock_quantity    Int           @default(0)
  stock_status      StockStatus   @default(INSTOCK)

  weight_grams      Float?
  length_cm         Float?
  width_cm          Float?
  height_cm         Float?

  meta_title        String?
  meta_description  String?

  /// All vendor-specific fields that don't fit the core schema.
  /// Sent to WooCommerce as meta_data[].
  attributes        Json          @default("{}")

  tags              String[]
  source_name       String?

  images            Image[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum ProductStatus {
  DRAFT
  REVIEW
  PUBLISHED
}

enum StockStatus {
  INSTOCK
  OUTOFSTOCK
  ONBACKORDER
}

model Image {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  position  Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─── WooCommerce Connection ──────────────────────────────────────────────────

model WooCommerceConnection {
  id             String   @id @default(cuid())
  name           String
  url            String
  /// AES-256-GCM encrypted consumer key
  consumerKey    String
  /// AES-256-GCM encrypted consumer secret
  consumerSecret String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── CSV Mapping Preset ──────────────────────────────────────────────────────

model CsvMappingPreset {
  id        String   @id @default(cuid())
  name      String
  /// { [csvColumn: string]: productField | "__ignore__" }
  mapping   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Import Session ──────────────────────────────────────────────────────────

model ImportSession {
  id              String        @id @default(cuid())
  filename        String
  /// Full CSV content stored temporarily during the import workflow
  csvContent      String
  rowCount        Int           @default(0)
  mapping         Json?
  presetId        String?
  status          ImportStatus  @default(PENDING)
  productsCreated Int           @default(0)
  errors          Json          @default("[]")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum ImportStatus {
  PENDING
  EXECUTING
  DONE
  ERROR
}

// ─── Export Job ──────────────────────────────────────────────────────────────

model ExportJob {
  id           String       @id @default(cuid())
  connectionId String
  productIds   String[]
  status       ExportStatus @default(PENDING)
  total        Int          @default(0)
  exported     Int          @default(0)
  errors       Json         @default("[]")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum ExportStatus {
  PENDING
  RUNNING
  DONE
  ERROR
}
