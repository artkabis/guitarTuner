# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL="postgresql://pim:pim@localhost:5432/pim"

# AES-256-GCM key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace_with_64_char_hex_string_here_000000000000000000000000000000"

# API
PORT=3001
CORS_ORIGIN="http://localhost:5173"
